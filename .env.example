# DMAESTRO Environment Configuration

# ML Server URL (Demucs + MR-MT3)
# Default: http://localhost:5000
# For remote ML server, set to the IP address of the machine running ml-server
# Example: http://192.168.1.100:5000
ML_SERVER_URL=http://localhost:5000

# Session secret for cookie-based auth (set this on Vercel)
SESSION_SECRET=change-me

# Frontend API base for Vite (Vercel build-time env var)
# Example:
# - Local: http://localhost:3001/api
# - Deployed backend: https://your-backend.example.com/api
VITE_API_BASE=http://localhost:3001/api

# CORS allow-list (comma-separated). Leave blank for same-origin deployments.
# Example: http://localhost:5173,https://finaldmaestro.vercel.app
CORS_ORIGIN=http://localhost:5173

# Persistent database (recommended for production)
# This project uses SQLite schema and can run on Turso/libSQL in production.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Replicate API Token (optional, for cloud stem separation)
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token_here
