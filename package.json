{
  "name": "dmaestro",
  "version": "1.0.0",
  "description": "Music education platform with AI transcription",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "vercel-build": "vite build && node scripts/vercel-backend-build.mjs",
    "db:migrate:turso": "node scripts/migrate-sqlite-to-turso.mjs --truncate",
    "db:migrate:turso:repair": "node scripts/migrate-sqlite-to-turso.mjs --truncate --repair",
    "db:reset-password:turso": "node scripts/turso-reset-password.mjs",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:klangio": "node ./node_modules/typescript/bin/tsc -p tsconfig.klangio-test.json && node --experimental-specifier-resolution=node test-node/klangio.runner.mjs",
    "test:klangio:all": "node ./node_modules/typescript/bin/tsc -p tsconfig.klangio-test.json && node --experimental-specifier-resolution=node test-node/klangio.all-outputs.runner.mjs",
    "test:music-utils": "node ./node_modules/typescript/bin/tsc -p tsconfig.music-utils-test.json && node --experimental-specifier-resolution=node test-node/music-library-utils.runner.mjs",
    "test:preview-utils": "node ./node_modules/typescript/bin/tsc -p tsconfig.music-preview-utils-test.json && node --experimental-specifier-resolution=node test-node/music-preview-utils.runner.mjs",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "keywords": [
    "music",
    "education",
    "transcription",
    "AI"
  ],
  "author": "DMAESTRO",
  "license": "ISC",
  "dependencies": {
    "@libsql/client": "^0.15.12",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@tanstack/react-query": "^5.60.0",
    "@tonejs/midi": "^2.0.28",
    "audio-decode": "^3.9.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.32.0",
    "express": "^4.19.0",
    "form-data": "^4.0.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "multer": "^1.4.5-lts.1",
    "opensheetmusicdisplay": "^1.9.7",
    "pitchy": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.8.0",
    "replicate": "^1.4.0",
    "tailwind-merge": "^2.3.0",
    "tone": "^15.0.4",
    "wavesurfer.js": "^7.8.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.0",
    "drizzle-kit": "^0.23.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.0",
    "typescript": "^6.0.2",
    "vite": "^7.1.3",
    "vitest": "^2.1.9"
  }
}
